<Window x:Class="WindowsBackupHelper.App.Views.CredentialTargetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Credential" Height="280" Width="420" WindowStartupLocation="CenterOwner" SizeToContent="Height"
        Icon="pack://application:,,,/Assets/icon.ico"
        FocusManager.FocusedElement="{Binding ElementName=LabelTextBox}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Label (e.g. 'Synology 1 — backups')" Margin="0,0,0,2" />
        <TextBox x:Name="LabelTextBox" Grid.Row="1" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Host or UNC root (e.g. \\nas1)" Margin="0,0,0,2" />
        <TextBox Grid.Row="3" Text="{Binding HostOrUncRoot, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <TextBlock Text="Username" Margin="0,0,0,2" />
                <TextBox Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                <TextBlock Text="Password (blank = keep existing)" Margin="0,0,0,2" />
                <PasswordBox Name="PasswordBox" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True" />
            <Button Content="Save" Width="90" IsDefault="True" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
