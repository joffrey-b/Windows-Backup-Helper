<UserControl x:Class="WindowsBackupHelper.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WindowsBackupHelper.App.Views">
    <!--
        A single Grid, not an outer ScrollViewer wrapping RobocopyOptionsEditor: that control has
        its own internal ScrollViewer (needed for its two other call sites, which don't wrap it
        in anything scrollable). Nesting it inside a second, page-level ScrollViewer meant
        clicking a checkbox inside it bubbled a RequestBringIntoView up to the OUTER ScrollViewer
        too, auto-scrolling the whole page and shoving the FLAC/notifications/workers section
        (above it) out of view. Giving the editor its own "*" row instead means only its own
        ScrollViewer ever needs to scroll, and the section above it never moves.
    -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Settings" FontWeight="Bold" FontSize="16" Margin="0,0,0,8" />

        <StackPanel Grid.Row="1">
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="FLAC executable path:" VerticalAlignment="Center" Width="160" />
                <TextBox Text="{Binding FlacExecutablePath}" Width="400" />
                <Button Content="Browse..." Command="{Binding BrowseFlacExecutablePathCommand}" Margin="8,0,0,0" />
            </StackPanel>
            <TextBlock Text="Leave blank to rely on PATH (flac.exe)." Foreground="Gray" Margin="164,0,0,8" />

            <CheckBox Content="Desktop notifications on job completion" IsChecked="{Binding NotificationsEnabled}" Margin="0,4" />

            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="Default checksum workers:" VerticalAlignment="Center" Width="160" />
                <TextBox Text="{Binding DefaultChecksumWorkers, TargetNullValue=''}" Width="60" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="Default FLAC workers:" VerticalAlignment="Center" Width="160" />
                <TextBox Text="{Binding DefaultFlacWorkers, TargetNullValue=''}" Width="60" />
            </StackPanel>

            <Separator Margin="0,12" />
            <TextBlock Text="App-wide default Robocopy options" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8"
                       Text="Every job ultimately falls back to these — Retries and Wait seconds here are the only place they're guaranteed to be set, since Robocopy's own defaults (1,000,000 retries x 30s) are effectively 'hang forever'." />
        </StackPanel>

        <local:RobocopyOptionsEditor Grid.Row="2" DataContext="{Binding DefaultOptionSet}" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Width="90" Margin="0,0,8,0" />
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Foreground="DarkSlateGray" />
        </StackPanel>
    </Grid>
</UserControl>
