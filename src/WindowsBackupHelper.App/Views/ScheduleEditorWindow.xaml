<Window x:Class="WindowsBackupHelper.App.Views.ScheduleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WindowsBackupHelper.App.Views"
        Title="Schedule" Height="420" Width="420" WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/Assets/icon.ico"
        FocusManager.FocusedElement="{Binding ElementName=TimeOfDayTextBox}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding JobName, StringFormat='Schedule for \'{0}\''}" FontWeight="Bold" Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Frequency:" VerticalAlignment="Center" Width="90" />
            <ComboBox ItemsSource="{x:Static local:EnumValueSource.Frequencies}" SelectedItem="{Binding Frequency}" Width="150" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Time (HH:mm):" VerticalAlignment="Center" Width="90" />
            <TextBox x:Name="TimeOfDayTextBox" Text="{Binding TimeOfDay, UpdateSourceTrigger=PropertyChanged}" Width="80" />
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Days (weekly only):" Margin="0,0,0,4" />
        <UniformGrid Grid.Row="4" Columns="4" Margin="0,0,0,8">
            <CheckBox Content="Sun" IsChecked="{Binding Sunday}" Margin="2" />
            <CheckBox Content="Mon" IsChecked="{Binding Monday}" Margin="2" />
            <CheckBox Content="Tue" IsChecked="{Binding Tuesday}" Margin="2" />
            <CheckBox Content="Wed" IsChecked="{Binding Wednesday}" Margin="2" />
            <CheckBox Content="Thu" IsChecked="{Binding Thursday}" Margin="2" />
            <CheckBox Content="Fri" IsChecked="{Binding Friday}" Margin="2" />
            <CheckBox Content="Sat" IsChecked="{Binding Saturday}" Margin="2" />
        </UniformGrid>

        <CheckBox Grid.Row="5" Content="Schedule enabled" IsChecked="{Binding IsScheduleEnabled}" Margin="0,0,0,8" />

        <CheckBox Grid.Row="6" Content="Run whether user is logged on or not (advanced)"
                  IsChecked="{Binding RunWhetherUserLoggedOnOrNot}" Margin="0,0,0,4" />
        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,0,0,8"
                    Visibility="{Binding RunWhetherUserLoggedOnOrNot, Converter={x:Static local:BoolToVisibilityConverter.Instance}}">
            <TextBlock Text="Your Windows password:" VerticalAlignment="Center" Width="150" />
            <PasswordBox Name="AccountPasswordBox" Width="150" />
        </StackPanel>

        <TextBlock Grid.Row="8" Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="Gray" VerticalAlignment="Top" />

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Remove schedule" Width="120" Margin="0,0,8,0" Click="Remove_Click"
                    Visibility="{Binding HasExistingSchedule, Converter={x:Static local:BoolToVisibilityConverter.Instance}}" />
            <Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True" />
            <Button Content="Save" Width="90" IsDefault="True" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
