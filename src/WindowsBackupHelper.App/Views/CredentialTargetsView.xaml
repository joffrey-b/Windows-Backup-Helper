<UserControl x:Class="WindowsBackupHelper.App.Views.CredentialTargetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Text="Credential targets" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="Gray"
                   Text="These are pointers into Windows Credential Manager only — no password ever touches this app's own database. Usernames/passwords live exclusively in the OS vault." />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Add..." Command="{Binding AddCommand}" Width="90" Margin="0,0,8,0" />
            <Button Content="Edit..." Command="{Binding EditCommand}" Width="90" Margin="0,0,8,0" />
            <Button Content="Delete" Command="{Binding DeleteCommand}" Width="90" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}"
                  AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                <DataGridTextColumn Header="Host / UNC root" Binding="{Binding HostOrUncRoot}" Width="*" />
                <DataGridTextColumn Header="Credential Manager target name" Binding="{Binding CredentialManagerTargetName}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
