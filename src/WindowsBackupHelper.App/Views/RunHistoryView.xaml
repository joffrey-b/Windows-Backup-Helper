<UserControl x:Class="WindowsBackupHelper.App.Views.RunHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Run history" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Delete run" Command="{Binding DeleteSelectedRunCommand}" Width="100" Margin="0,0,8,0" />
                <Button Content="Clear all history" Command="{Binding ClearAllHistoryCommand}" Width="120" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRun}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Job" Binding="{Binding JobName}" Width="*" />
                <DataGridCheckBoxColumn Header="Job referenced" Binding="{Binding JobReferenced}" />
                <DataGridTextColumn Header="Trigger" Binding="{Binding Run.TriggerType}" />
                <DataGridTextColumn Header="Started (UTC)" Binding="{Binding Run.StartedUtc}" />
                <DataGridTextColumn Header="Completed (UTC)" Binding="{Binding Run.CompletedUtc}" />
                <DataGridCheckBoxColumn Header="Dry run" Binding="{Binding Run.WasDryRun}" />
                <DataGridTextColumn Header="Outcome" Binding="{Binding Run.OverallOutcome}" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Text="Folder pair results for selected run" FontWeight="Bold" Margin="0,8,0,4" />

        <DataGrid Grid.Row="3" ItemsSource="{Binding SelectedRunResults}" AutoGenerateColumns="False" IsReadOnly="True"
                  MouseDoubleClick="ResultsDataGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Pair referenced" Binding="{Binding PairReferenced}" />
                <DataGridTextColumn Header="Exit code" Binding="{Binding Result.RobocopyExitCode}" />
                <DataGridTextColumn Header="Summary" Binding="{Binding Result.RobocopyOutcomeSummary}" Width="*" />
                <DataGridTextColumn Header="Files copied" Binding="{Binding Result.FilesCopied}" />
                <DataGridTextColumn Header="Bytes copied" Binding="{Binding Result.BytesCopied}" />
                <DataGridTextColumn Header="Checksum" Binding="{Binding Result.ChecksumOutcomeSummary}" Width="*" />
                <DataGridTextColumn Header="FLAC" Binding="{Binding Result.FlacOutcomeSummary}" Width="*" />
                <DataGridTextColumn Header="Error" Binding="{Binding Result.ErrorMessage}" Width="*" />
                <DataGridTextColumn Header="Log file (double-click a row to open)" Binding="{Binding Result.RobocopyLogFilePath}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
