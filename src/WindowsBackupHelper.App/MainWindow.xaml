<Window x:Class="WindowsBackupHelper.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WindowsBackupHelper.App.Views"
        Title="Windows Backup Helper" Height="720" Width="1100" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/icon.ico">
    <TabControl Margin="4" SelectionChanged="TabControl_SelectionChanged">
        <TabItem Header="Jobs">
            <views:JobsView DataContext="{Binding Jobs}" />
        </TabItem>
        <TabItem Header="Credentials">
            <views:CredentialTargetsView DataContext="{Binding Credentials}" />
        </TabItem>
        <TabItem Header="Settings">
            <views:SettingsView DataContext="{Binding Settings}" />
        </TabItem>
        <TabItem x:Name="RunHistoryTab" Header="Run History">
            <views:RunHistoryView DataContext="{Binding RunHistory}" />
        </TabItem>
        <TabItem Header="Verify Backup">
            <views:StandaloneVerificationView DataContext="{Binding StandaloneVerification}" />
        </TabItem>
        <TabItem Header="Help">
            <views:HelpView />
        </TabItem>
    </TabControl>
</Window>
